<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="CortexTerminal.Mobile.App.MainPage"
             SafeAreaEdges="None"
             Shell.TabBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{Binding NativeStatusBarColor}"
                                   StatusBarStyle="{Binding NativeStatusBarStyle}"/>
    </ContentPage.Behaviors>

    <Grid RowDefinitions="*,Auto">
        <HybridWebView x:Name="hybridWebView"
                       Grid.Row="0"
                       HybridRoot="wwwroot"
                       DefaultFile="index.html"
                       Loaded="OnHybridWebViewLoaded"
                       WebResourceRequested="OnHybridWebViewWebResourceRequested"
                       RawMessageReceived="OnHybridWebViewRawMessageReceived"/>

        <Grid x:Name="splashScreen"
              Grid.RowSpan="2"
              BackgroundColor="#08080A"
              ZIndex="999">
            <Image Source="splash.svg"
                   Aspect="AspectFit"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"/>
        </Grid>
    </Grid>

</ContentPage>
